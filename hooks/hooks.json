{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "test -f .devblock/scope-guard.sh && bash .devblock/scope-guard.sh || true"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "test -f .devblock/scope-guard.sh && bash .devblock/scope-guard.sh || true"
          }
        ]
      }
    ]
  }
}
